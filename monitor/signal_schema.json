{
  "type": "object",
  "required": [
    "signal_type",
    "severity",
    "service",
    "metric",
    "value",
    "timestamp",
    "trace_id"
  ],
  "properties": {
    "signal_type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["INFO", "WARN", "CRITICAL"]
    },
    "service": {
      "type": "string"
    },
    "metric": {
      "type": "string",
      "enum": ["latency", "error_rate", "status"]
    },

    "value": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "enum": ["SUCCESS", "FAILURE", "RUNNING"]
        }
      ]
    },

    "timestamp": {
      "type": "integer"
    },

    "trace_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}