{
  "type": "object",
  "required": [
    "signal_type",
    "severity",
    "service",
    "metric",
    "value",
    "timestamp",
    "trace_id",
    "trace_origin",
    "source"
  ],
  "properties": {
    "signal_type": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["INFO", "WARN", "CRITICAL"]
    },
    "service":       { "type": "string" },
    "metric": {
      "type": "string",
      "enum": ["latency", "error_rate", "status", "restart_count"]
    },
    "value": {
      "oneOf": [
        { "type": "number" },
        { "type": "string", "enum": ["SUCCESS", "FAILURE", "RUNNING"] }
      ]
    },
    "timestamp":      { "type": "integer" },
    "trace_id":       { "type": "string", "minLength": 1 },
    "trace_origin":   { "type": "string", "enum": ["core"] },
    "source":         { "type": "string" },
    "trace_hash":     { "type": ["string", "null"] },
    "execution_id":   { "type": ["string", "null"] },
    "decision":       { "type": ["string", "null"] },
    "policy_reference": { "type": ["string", "null"] },
    "action":         { "type": ["string", "null"] },
    "enforcement_status": { "type": ["string", "null"] },
    "result":         { "type": ["string", "null"] },
    "emitted_at":     { "type": ["string", "null"] }
  },
  "additionalProperties": false
}